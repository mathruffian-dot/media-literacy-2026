# 把此檔複製成 .env 並填入你的 key（.env 已在 .gitignore，不會被 commit）
# 或者你也可以把 key 放到 ~/.groq_api_key 與 ~/.openai.env（全域備援，跨專案共用）

# Groq API Key — 給 audio-to-srt Skill 使用
# 取得：https://console.groq.com
GROQ_API_KEY=

# OpenAI API Key — 給 cover-image Skill 使用
# 取得：https://platform.openai.com（需 Individual 驗證才能用 gpt-image-2）
OPENAI_API_KEY=
